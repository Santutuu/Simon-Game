<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:padding="24dp">

    <!-- Header -->
    <ImageButton
        android:id="@+id/btnBackHome"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@android:color/transparent"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_home"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/textViewTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Estadísticas"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBackHome"
        app:layout_constraintStart_toEndOf="@+id/btnBackHome"
        app:layout_constraintTop_toTopOf="@+id/btnBackHome" />

    <!-- Big Score Circle with Simon Colors Ring -->
    <FrameLayout
        android:id="@+id/frameMejorPuntaje"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewTitle">

        <!-- Simon Colors Ring -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circulo_resultado"
            android:backgroundTint="#222222"
            android:clipToOutline="true"
            android:columnCount="2"
            android:rowCount="2">

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:background="#4CAF50"
                android:alpha="0.4" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:background="#F44336"
                android:alpha="0.4" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:background="#FFEB3B"
                android:alpha="0.4" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:background="#2196F3"
                android:alpha="0.4" />
        </GridLayout>

        <!-- Inner Dark Circle -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_circulo_resultado"
            android:backgroundTint="@color/bg_main" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.2"
                android:text="RECORD"
                android:textColor="@color/text_yellow"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtMejorPuntaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="99"
                android:textColor="@color/bright_yellow"
                android:textSize="110sp"
                android:textStyle="bold"
                android:shadowColor="@color/bright_yellow"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="25" />
        </LinearLayout>
    </FrameLayout>

    <!-- Secondary Stats -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@+id/frameMejorPuntaje">

        <!-- Nivel reached with Green accent -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="#4CAF50"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NIVEL MÁX"
                android:textColor="@color/text_yellow"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtNivelAlcanzado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08"
                android:textColor="@color/white"
                android:textSize="48sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Reaction time with Blue accent -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="#2196F3"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REACCIÓN"
                android:textColor="@color/text_yellow"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtReaccionPromedio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.2s"
                android:textColor="@color/white"
                android:textSize="48sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Decorative Glow (Full Simon colors) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#4CAF50" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F44336" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#FFEB3B" />
        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#2196F3" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>