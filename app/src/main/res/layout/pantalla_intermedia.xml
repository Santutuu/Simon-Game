<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".PantallaIntermediaActivity">

    <ImageButton
        android:id="@+id/btnHome"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="@android:color/transparent"
        android:contentDescription="Ir al menú"
        android:src="@drawable/ic_home"
        android:tint="#FFF4B1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtTituloResultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="ULTIMO SCORE"
            android:textAllCaps="true"
            android:textColor="#E7E35A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtUltimoScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="12"
            android:textColor="#E7E35A"
            android:textSize="34sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_simon_base_3d">

            <GridLayout
                android:layout_width="270dp"
                android:layout_height="270dp"
                android:layout_gravity="center"
                android:rowCount="2"
                android:columnCount="2"
                android:background="@drawable/bg_circulo_colores_simon"
                android:clipToOutline="true">

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_simon_green_3d" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_simon_red_3d" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_simon_yellow_3d" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/bg_simon_blue_3d" />
            </GridLayout>

            <View
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_simon_centro_3d" />

            <View
                android:layout_width="2dp"
                android:layout_height="270dp"
                android:layout_gravity="center"
                android:background="#242424" />

            <View
                android:layout_width="270dp"
                android:layout_height="2dp"
                android:layout_gravity="center"
                android:background="#242424" />

        </FrameLayout>

        <Button
            android:id="@+id/btnReiniciar"
            android:layout_width="180dp"
            android:layout_height="52dp"
            android:layout_marginTop="80dp"
            android:background="@drawable/bg_boton_principal_violeta"
            android:text="Reiniciar"
            android:textAllCaps="false"
            android:textColor="#F7F04A"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>