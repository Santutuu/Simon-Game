<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="16dp"
    tools:context=".JuegoActivity">

    <ImageButton
        android:id="@+id/btnHome"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:background="@android:color/transparent"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_home"
        android:contentDescription="Inicio"
        app:tint="#F4E04D" />

    <!-- CONTENEDOR DE VIDAS -->
    <LinearLayout
        android:id="@+id/layoutVidas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:orientation="horizontal"
        android:padding="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtPuntaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="100dp"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:id="@+id/scrollSecuencia"
            android:layout_width="320dp"
            android:layout_height="80dp"
            android:layout_marginTop="10dp"
            android:background="#000000"
            android:visibility="gone"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/contenedorCintaCine"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="140dp"
                android:paddingEnd="140dp" />
        </HorizontalScrollView>

        <RelativeLayout
            android:id="@+id/contenedorCarrera"
            android:layout_width="320dp"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:background="#222222"
            android:visibility="gone">
            <View
                android:layout_width="40dp"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:background="#FFD700"
                android:alpha="0.3" />
            <View
                android:id="@+id/pelotaCarrera"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_centerVertical="true"
                android:background="@drawable/ic_pelota" />
        </RelativeLayout>

        <TextView
            android:id="@+id/txtIndicadorColor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text=""
            android:visibility="invisible"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#F4E04D" />

        <LinearLayout
            android:id="@+id/contenedorSecuencia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="8dp">
            <LinearLayout android:id="@+id/filaSecuencia1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" />
            <LinearLayout android:id="@+id/filaSecuencia2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal" />
        </LinearLayout>

        <GridLayout
            android:id="@+id/gridSimon"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="100dp"
            android:background="#FFFFFF"
            android:columnCount="2"
            android:rowCount="2">
            <TextView android:id="@+id/cuadro1" android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_simon_green_3d" />
            <TextView android:id="@+id/cuadro2" android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_simon_red_3d" />
            <TextView android:id="@+id/cuadro3" android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_simon_yellow_3d" />
            <TextView android:id="@+id/cuadro4" android:layout_width="0dp" android:layout_height="0dp" android:layout_rowWeight="1" android:layout_columnWeight="1" android:layout_margin="2dp" android:background="@drawable/bg_simon_blue_3d" />
        </GridLayout>

        <GridLayout
            android:id="@+id/gridNumeros"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_marginTop="100dp"
            android:columnCount="3"
            android:rowCount="3"
            android:visibility="gone">
        </GridLayout>

        <LinearLayout
            android:id="@+id/contenedorBarraTiempo"
            android:layout_width="300dp"
            android:layout_height="24dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_barra_tiempo_fondo"
            android:orientation="horizontal"
            android:weightSum="1"
            android:padding="2dp">
            <View
                android:id="@+id/barraTiempoProgreso"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_barra_tiempo_progreso" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSiguienteEtapa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="EMPEZAR ETAPA 2"
            android:visibility="gone"
            android:backgroundTint="#F4E04D"
            android:textColor="#000000"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnPlay"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_play"
            app:tint="#F4E04D" />

    </LinearLayout>

</RelativeLayout>
